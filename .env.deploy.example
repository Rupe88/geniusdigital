# Droplet production — copy to frontend/.env.deploy (chmod 600).
# Used by: docker compose -f docker-compose.build.yml --env-file .env.deploy up -d --build
#
# Optional: pre-built image deploy (GHCR) uses docker-compose.prod.yml + FRONTEND_IMAGE instead — see deploy/DROPLET.md

# Public API (HTTPS)
NEXT_PUBLIC_API_URL=https://api.geniusshiksha.com/api

# Public site URL (canonical)
NEXT_PUBLIC_APP_URL=https://geniusshiksha.com

