# Copy to .env.deploy on the droplet (chmod 600). CI usually writes this file each deploy.
#
# Pre-built image from GHCR. For **cron pull** deploys, use the **:latest** tag (CI updates it every push).
# FRONTEND_IMAGE=ghcr.io/owner/geniusdigital:latest
# For immutable tags per commit (optional / SSH deploy): ghcr.io/owner/geniusdigital:<git-sha>

# Preferred (Netlify HTTPS → API HTTPS): use your Nginx TLS host — no proxy, no mixed content.
NEXT_PUBLIC_API_URL=https://api.geniusdigi.com/api

# Only if the API has NO public HTTPS URL: same-origin proxy (see next.config.ts rewrites).
# BACKEND_HTTP_ORIGIN=http://DROPLET_IP:4000
# NEXT_PUBLIC_API_URL=https://geniusdigi.netlify.app/backend-proxy/api

# Public site URL (SEO, canonical) — match Netlify URL or custom domain
NEXT_PUBLIC_APP_URL=https://geniusdigi.netlify.app
